# ==============================================================================
# 万能通用 .dockerignore 模板 (支持 Node, Rust, Go, Python, Java 等)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. 版本控制与临时文件
# ------------------------------------------------------------------------------
.git
.github
.gitlab
.gitignore
.gitattributes
*.log
*.tmp
*.bak
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# 2. 密钥、环境变理与安全（绝对不能打包进镜像）
# ------------------------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.pub
*.passwd
secrets/

# ------------------------------------------------------------------------------
# 3. 编程语言特定目录 (核心：忽略本地依赖和编译产物)
# ------------------------------------------------------------------------------

# === Node.js / Frontend ===
node_modules/
jspm_packages/
.npm/
.yarn/
.pnpm-store/
.next/
.nuxt/
dist/
build/
out/
.eslintcache

# === Rust ===
target/
**/*.rs.bk

# === Go ===
# Go 通常没有 node_modules 这种本地依赖包目录（在 GOMODCACHE），
# 但本地编译出的二进制程序通常在根目录，需要屏蔽
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.prof

# === Python ===
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
.manifest
.spec
.pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.tox/

# ------------------------------------------------------------------------------
# 4. IDE、编辑器与工具配置
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ------------------------------------------------------------------------------
# 5. Docker 自身文件（防止自己复制自己引发缓存失效）
# ------------------------------------------------------------------------------
Dockerfile
.dockerignore
docker-compose*.yml
